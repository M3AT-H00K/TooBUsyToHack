<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Page</title>

    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/userpage.css">
</head>
<body>
    <h2 class ="type-writer"> Welcome, <%= userid %></h2>

    <button class="btn-tasks" id="taskButton"> Tasks </button>
    <button class="btn-rivals" id="rivalButton"> Rival </button>

    <!-- Modal Structure for Tasks -->
    <div class="modal" id="taskModal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="task-label">Task</span> <!-- Changed task label to Task -->
                <span class="time-left" id="timeLeft">Time Left: 00:00</span>
                <button class="close-btn" id="closeModal">&times;</button>
            </div>
            <form id="taskForm">
                <div class="task-box">Calculus Assignment 2</div> <!-- Updated task description to be a box with text -->
                <button class="download-attachment">Download Attachment</button> <!-- Changed to a button -->
                <label for="fileUpload" class="custom-file-upload">Add File</label> <!-- Custom Add File button -->
                <input type="file" id="fileUpload" />
                <button type="submit">Submit</button>
            </form>
        </div>
    </div>

    <!-- Modal Structure for Rival -->
    <div class="modal" id="rivalModal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="task-label">Rival</span>
                <span class="time-left" id="rivalTimeLeft">08:15:21</span>
                <button class="close-btn" id="closeRivalModal">&times;</button>
            </div>
            <div class="rival-info">
                <p>Your Rival is:</p>
                <h2>23223413</h2>
                <p>Status:</p>
                <h3>Not Submitted</h3>
            </div>
        </div>
    </div>

    <div class="settings-icon" id="settingsButton">
        <i class="material-icons" style="font-size: 88px;">settings</i> <!-- Increased the font size of the icon -->
    </div>

    <div class="modal" id="settingsModal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="task-label">Settings</span>
                <button class="close-btn" id="closeSettingsModal">&times;</button>
            </div>
            <form id="settingsForm">
                <label for="department">Department</label>
                <select id="department" name="department">
                    <option value="cs">Computer Science</option>
                    <option value="math">Mathematics</option>
                    <option value="physics">Physics</option>
                </select>

                <label for="year">Year</label>
                <select id="year" name="year">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                </select>

                <button type="submit">Save</button>
            </form>
        </div>
    </div>

    <script src="/javascripts/userpage.js"></script>
</body>
</html>